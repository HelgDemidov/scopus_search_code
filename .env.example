# ============================================================
# API Key для Elsevier/Scopus (зарегистрировать на dev.elsevier.com)
# ============================================================
SCOPUS_API_KEY=your_scopus_api_key_here

# ==========================================================================================
# Параметры для локального подключения к БД PostgreSQL
# ==========================================================================================
# PostgreSQL Database
# DB_HOST=db
# DB_PORT=5432
# DB_USER=scopus_db_user
# DB_PASSWORD=[your_DB_password]
# DB_NAME=scopus_db


# ============================================================
# JWT Security
# ============================================================
SECRET_KEY=your_super_secret_key_for_jwt_generation
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ============================================================
# Параметры Connection String (Supabase, Session Pooler) для подключения бэкенда (Railway) к облачной БД
# ============================================================
# Supabase Connection String (Session Pooler) - значение для Production Environment:
DATABASE_URL=postgresql+asyncpg://[user]:[production instance DB password]@[host]:[port]/[database]
# Supabase Connection String (Session Pooler) - значение для Staging Environment:
DATABASE_SUPABASE_STAGING_URL=postgresql+asyncpg://[user]:[staging instance DB password]@[host]:[port]/[database]


# ============================================================
# Параметры Backend Base URL (Staging Environment)
# ============================================================
# Публичный URL бэкенда проекта на Railway - значение для Staging Environment (также задан в GithubSecrets)
RAILWAY_STAGING_BASE_URL=https://[project-name-staging].up.railway.app


# ============================================================
# Параметры автоматического сидера (GitHub Actions / локальный запуск)
# Указывать значение Secret (32-символьная строка), 
# через который сидер получает доступ (через GithubSecrets, Railway Variables)
# ============================================================
SEEDER_SECRET=your_32_char_secret_here


# ============================================================
# OpenRouter API — генерация уникальных поисковых фраз через LLM
# Получить на openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here


# ============================================================
# Google OAuth 2.0
# Получить в Google Cloud Console — APIs & Services → Credentials → scopus-railway-client
# ============================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
SESSION_SECRET_KEY=your_session_secret_key_here


# ============================================================
# Frontend URL (dev mode)
# ============================================================
FRONTEND_URL=[your localhost URL]


# ============================================================
# Credentials тестового пользователя Staging DB Supabase 
# используются для прогона E2E-тестов (Staging Environment) в GithubActions e2e CI
# ============================================================
STAGING_TEST_EMAIL=[staging_test_user_email]
STAGING_TEST_PASSWORD=[staging_test_user_password]


# ============================================================
# Переменные для локального запуска E2E-тестов
# Тест-файлы читают E2E_* — не зависят от имён Railway-переменных
# ============================================================

# E2E-тесты — Staging Environment (DEFAULT для локального запуска)
# ============================================================
# Публичный URL бэкенда проекта на Railway - значение для Staging Environment
E2E_BASE_URL=https://[project-name-staging].up.railway.app
# Credentials тестового пользователя Staging DB Supabase для прогона E2E-тестов (Staging Environment)
# маппятся в STAGING_TEST_EMAIL и STAGING_TEST_PASSWORD в GithubActions e2e CI
E2E_TEST_EMAIL=[staging_test_user_email]
E2E_TEST_PASSWORD=[staging_test_user_password]

# E2E-тесты — Production Environment (РАСКОММЕНТИРОВАТЬ для prod-запуска):
# ============================================================
# E2E_BASE_URL=https://[project-name].up.railway.app
# E2E_TEST_EMAIL=[prod_test_user_email]
# E2E_TEST_PASSWORD=[prod_test_user_password]
