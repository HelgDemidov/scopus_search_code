# ============================================================
# API Key для Elsevier/Scopus (зарегистрировать на dev.elsevier.com)
# ============================================================
SCOPUS_API_KEY=your_scopus_api_key_here


# ==========================================================================================
# УСТАРЕВШИЕ параметры локального Docker-Postgres (не используются)
# Артефакт этапа разработки, когда БД поднималась через docker-compose.
# Сейчас для подключения бэкенда используется DATABASE_URL (Supabase Session Pooler).
# Для тестов с маркером requires_pg — DATABASE_TEST_URL (throwaway PG, см. ниже).
# ==========================================================================================
# # DB_HOST=db
# # DB_PORT=5432
# # DB_USER=scopus_db_user
# # DB_PASSWORD=...
# # DB_NAME=scopus_db


# ============================================================
# JWT Security
# ============================================================
SECRET_KEY=your_super_secret_key_32_chars_minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ==========================================================================================
# Параметры Connection String для подключения бэкенда (Railway) к облачной БД Supabase
# ==========================================================================================
# Supabase Connection String (Session Pooler) - значение для Production Environment
DATABASE_URL=postgresql+asyncpg://[user]:[password]@[production-host]:[port]/postgres
# Supabase Connection String (Session Pooler) - значение для Staging Environment
DATABASE_SUPABASE_STAGING_URL=postgresql+asyncpg://[user]:[password]@[staging-host]:[port]/postgres


# ============================================================
# Параметры Backend Base URL (Staging Environment)
# ============================================================
# Публичный URL бэкенда проекта на Railway - значение для Staging Environment (также задан в GithubSecrets)
RAILWAY_STAGING_BASE_URL=https://[your-project-staging].up.railway.app


# ============================================================
# Параметры автоматического сидера (GitHub Actions / локальный запуск)
# Secret (32-символьная строка), через который сидер получает доступ (через GithubSecrets, Railway Variables)
# ============================================================
SEEDER_SECRET=your_32_char_seeder_secret_here


# ============================================================
# Google OAuth 2.0
# Получен в Google Cloud Console — APIs & Services → Credentials → scopus-railway-client
# ============================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
SESSION_SECRET_KEY=your_session_secret_key_32_chars_minimum


# ============================================================
# Frontend URL (dev mode)
# ============================================================
FRONTEND_URL=http://localhost:5173


# ============================================================
# Credentials тестового пользователя Staging DB Supabase
# Локальные копии для справки. В CI значения задаются как GitHub Secrets
# STAGING_TEST_EMAIL / STAGING_TEST_PASSWORD и читаются e2e.yml напрямую оттуда,
# а не из .env. Локально используются как E2E_TEST_EMAIL / E2E_TEST_PASSWORD ниже.
# ============================================================
STAGING_TEST_EMAIL=staging_test_user@example.com
STAGING_TEST_PASSWORD=YourTestPass123!


# ============================================================
# Переменные для локального запуска E2E-тестов
# Тест-файлы читают E2E_* — не зависят от имён Railway-переменных
# ============================================================

# E2E-тесты — Staging Environment (DEFAULT для локального запуска)
# ============================================================
# Публичный URL бэкенда проекта на Railway - значение для Staging Environment
E2E_BASE_URL=https://[your-project-staging].up.railway.app
# Credentials тестового пользователя Staging DB Supabase для прогона E2E-тестов
# В GitHub Actions e2e.yml: GH Secrets STAGING_TEST_EMAIL / STAGING_TEST_PASSWORD
# → env vars E2E_TEST_EMAIL / E2E_TEST_PASSWORD (тест-файлы читают именно E2E_*)
E2E_TEST_EMAIL=staging_test_user@example.com
E2E_TEST_PASSWORD=YourTestPass123!

# E2E-тесты — Production Environment (РАСКОММЕНТИРОВАТЬ для prod-запуска):
# ============================================================
# E2E_BASE_URL=https://[your-project].up.railway.app
# E2E_TEST_EMAIL=[prod_test_user_email]
# E2E_TEST_PASSWORD=[prod_test_user_password]


# ============================================================
# DATABASE_TEST_URL — ТОЛЬКО для тестов с маркером @pytest.mark.requires_pg
# ============================================================
# КРИТИЧНО: тесты вызывают Base.metadata.drop_all — они УНИЧТОЖАТ данные в любой
# реальной БД. Никогда не указывать здесь staging или production Supabase!
#
# Для локального запуска requires_pg тестов поднять throwaway PostgreSQL:
#   docker run -d --name scopus_test_pg \
#     -e POSTGRES_USER=testuser -e POSTGRES_PASSWORD=testpass \
#     -e POSTGRES_DB=testdb -p 5432:5432 postgres:16
#
# DATABASE_TEST_URL=postgresql+asyncpg://testuser:testpass@localhost:5432/testdb
#
# (CI job test-pg использует то же самое значение через встроенный PG 16 контейнер)
