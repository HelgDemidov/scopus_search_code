# ============================================================
# API Key для Elsevier/Scopus (зарегистрировать на dev.elsevier.com)
# ============================================================
SCOPUS_API_KEY=your_scopus_api_key_here

# ==========================================================================================
# Параметры для локального подключения к БД PostgreSQL
# ==========================================================================================
# PostgreSQL Database
# DB_HOST=db
# DB_PORT=5432
# DB_USER=scopus_db_user
# DB_PASSWORD=[your_DB_password]
# DB_NAME=scopus_db

# ============================================================
# Параметры Connection String (Supabase, Session Pooler) для подключения бэкенда (Railway) к облачной БД
# ============================================================
# Supabase Connection String (Session Pooler) - значение для Production Environment:
DATABASE_URL=postgresql+asyncpg://[user]:[production instance DB password]@[host]:[port]/[database]
# Supabase Connection String (Session Pooler) - значение для Staging Environment:
DATABASE_SUPABASE_STAGING_URL=postgresql+asyncpg://[user]:[staging instance DB password]@[host]:[port]/[database]

# ============================================================
# JWT Security
# ============================================================
SECRET_KEY=your_super_secret_key_for_jwt_generation
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# Параметры автоматического сидера (GitHub Actions / локальный запуск)
# Указывать значение Secret (32-символьная строка), 
# через который сидер получает доступ (через GithubSecrets, Railway Variables)
# ============================================================
SEEDER_SECRET=your_32_char_secret_here

# ============================================================
# OpenRouter API — генерация уникальных поисковых фраз через LLM
# Получить на openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================================
# Google OAuth 2.0
# Получить в Google Cloud Console — APIs & Services → Credentials → scopus-railway-client
# ============================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
SESSION_SECRET_KEY=your_session_secret_key_here

# Frontend URL (dev mode)
FRONTEND_URL=[your localhost URL]
