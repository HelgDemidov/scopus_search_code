# ============================================================
# API Key для Elsevier/Scopus (зарегистрировать на dev.elsevier.com)
# ============================================================
SCOPUS_API_KEY=your_scopus_api_key_here

# ============================================================
# Настройки базы данных (Supabase, Session Pooler)
# Пример: postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]
# ============================================================
DATABASE_URL=postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]

# ============================================================
# JWT Security
# ============================================================
SECRET_KEY=your_super_secret_key_for_jwt_generation
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# Параметры автоматического сидера (GitHub Actions / локальный запуск)
# Указывать credentials админ-пользователя, от имени которого сидер будет логиниться
# ============================================================
SEEDER_EMAIL=admin@example.com
SEEDER_PASSWORD=your_admin_password_here

# ============================================================
# OpenRouter API — генерация уникальных поисковых фраз через LLM
# Получить на openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================================
# Google OAuth 2.0
# Получить в Google Cloud Console — APIs & Services → Credentials → scopus-railway-client
# ============================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your_session_secret_key_here
