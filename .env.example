# API Key для Elsevier/Scopus (зарегистрировать на dev.elsevier.com)
SCOPUS_API_KEY=your_scopus_api_key_here

# Настройки базы данных (единая строка подключения)
# Пример для локальной БД: postgresql+asyncpg://postgres:postgres@localhost:5432/testdb
# Пример для Supabase (ВАЖНО: используйте Session Pooler): 
DATABASE_URL=postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]

# Настройки безопасности (JWT)
SECRET_KEY=your_super_secret_key_for_jwt_generation
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
