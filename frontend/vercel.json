{
  "redirects": [
    { "source": "/explore",         "destination": "/en/explore",         "permanent": true },
    { "source": "/auth",            "destination": "/en/auth",            "permanent": true },
    { "source": "/profile",         "destination": "/en/profile",         "permanent": true },
    { "source": "/article/:id",     "destination": "/en/article/:id",     "permanent": true },
    { "source": "/forgot-password", "destination": "/en/forgot-password", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/auth/google/:path*",
      "destination": "https://scopus-search-code.up.railway.app/auth/google/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://scopus-search-code.up.railway.app/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/google:path*",
      "destination": "/google:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://scopus-search-code.up.railway.app https://va.vercel-scripts.com https://vitals.vercel-insights.com https://www.google-analytics.com https://www.googletagmanager.com https://o4511716808589312.ingest.de.sentry.io; img-src 'self' data:; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
