# eslint-plugin-jsx-a11y@6.10.2 (последний релиз, окт. 2024) объявляет
# peerDependencies eslint@^3...^9 — не успел за ESLint 10, который проект
# уже использует. На практике плагин работает корректно поверх flat config
# ESLint 10 (проверено: npm run lint), диапазон peer-зависимости просто устарел.
# Без этой строки `npm ci` падает с ERESOLVE на самом первом шаге любой
# фронтенд CI-джобы и на деплое Vercel.
legacy-peer-deps=true
